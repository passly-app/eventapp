{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "outDir": "lib",
    "rootDir": "src",
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "types": [
      "node"
    ]
  },
  "compileOnSave": true,
  "include": [
    "src",
    "env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "*.spec.ts"
  ]
}