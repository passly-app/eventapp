    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsc": "^2.0.4",
    "tsc-alias": "^1.8.11",
    "typescript": "latest",
    "typescript-transform-paths": "^3.5.3"
  }
