{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "composite": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "**/*.spec.ts",
        "dist"
    ]
}